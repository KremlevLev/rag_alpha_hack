# ── API Keys (enterprise features — optional) ──
# Unstructured API (for advanced PDF parsing)
UNSTRUCTURED_API_KEY=
# Voyage AI (for enterprise embeddings)
VOYAGE_API_KEY=
# Cohere (for Rerank v3)
COHERE_API_KEY=
# Anthropic Claude (for generation)
ANTHROPIC_API_KEY=
# OpenRouter (alternative LLM provider)
OPENROUTER_API_KEY=
# LangSmith tracing
LANGSMITH_API_KEY=

# ── Qdrant (enterprise vector store) ──
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=enterprise_rag

# ── LLM Selection (enterprise generation) ──
LLM_PROVIDER=openrouter
LLM_MODEL=anthropic/claude-3.5-sonnet

# ── Tracing ──
TRACING_PROVIDER=null
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:4317